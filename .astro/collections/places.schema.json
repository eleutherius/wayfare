{
  "$ref": "#/definitions/places",
  "definitions": {
    "places": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "lat": {
          "type": "number"
        },
        "lng": {
          "type": "number"
        },
        "category": {
          "type": "string",
          "enum": [
            "coffee",
            "food",
            "sight",
            "viewpoint",
            "stay",
            "other"
          ]
        },
        "city": {
          "type": "string"
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "cover": {
          "type": "string"
        },
        "rating": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "lat",
        "lng",
        "category",
        "city",
        "date"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}