---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import LeafletMap from "@/components/LeafletMap.astro";
import { googleMaps, appleMaps } from "@/lib/maplinks";
import type { MarkerData } from "@/lib/types";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const allPlaces = await getCollection("places");

const markers: MarkerData[] = allPlaces.map((p) => ({
  lat: p.data.lat,
  lng: p.data.lng,
  title: p.data.title,
  slug: p.id,
  category: p.data.category,
  googleUrl: googleMaps(p.data.lat, p.data.lng),
  appleUrl: appleMaps(p.data.lat, p.data.lng, p.data.title),
}));
---

<Base title="Map" description="Overview map of all visited places" base={base} bodyClass="map-page">
  <LeafletMap id="overview-map" {markers} height="100%" zoom={12} base={base} />
</Base>

<style is:global>
  body.map-page #overview-map {
    border-radius: 0;
    flex: 1;
    min-height: 0;
  }
</style>
