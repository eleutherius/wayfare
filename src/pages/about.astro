---
import Base from "@/layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base
  title="About"
  description="About the Wayfare project — a personal travel map"
  base={base}
>
  <article class="about">
    <h1 class="about__title">About this project</h1>

    <div class="about__body">
      <p>
        Wayfare is a personal map of places worth remembering. Coffee shops
        tucked into side streets, temples that empty out after noon, street
        kitchens with no English menu, viewpoints that don't appear in any
        guidebook. Places visited, written about, and linked to maps so they're
        easy to find again.
      </p>
      <p>
        Every pin has been visited in person. Every note is written from memory
        — not pulled from a review site, not generated. If a place appears here,
        it made enough of an impression to be recorded.
      </p>
      <p>
        This is not a guide. There are no ratings designed to rank places
        against each other, no sponsored listings, no affiliate links. It's
        closer to a travel notebook made navigable — a record of where I've
        been and what I thought was worth remembering.
      </p>
      <p>
        The map grows slowly, city by city, as new places get added after
        trips. Older entries occasionally get updated when I return somewhere.
      </p>
    </div>

    <a href={`${base}/`} class="about__back">← Back to map</a>
  </article>
</Base>

<style>
  .about {
    max-width: 60ch;
    padding-top: 1rem;
  }

  .about__title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    margin: 0 0 2rem;
  }

  .about__body p {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--ink);
    margin: 0 0 1.25rem;
  }

  .about__back {
    display: inline-block;
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    text-decoration: none;
    border-bottom: 1px solid var(--line-strong);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .about__back:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }
</style>
