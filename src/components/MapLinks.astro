---
import { googleMaps, googleDirections, appleMaps } from "@/lib/maplinks";

interface Props {
  lat: number;
  lng: number;
  title: string;
  /** Show directions button instead of (or in addition to) search */
  directions?: boolean;
  class?: string;
}

const { lat, lng, title, directions = false, class: cls } = Astro.props;

const gmSearch = googleMaps(lat, lng);
const gmDir = googleDirections(lat, lng);
const am = appleMaps(lat, lng, title);
---

<div class:list={["map-links", cls]}>
  <a
    href={directions ? gmDir : gmSearch}
    target="_blank"
    rel="noopener noreferrer"
    class="map-btn map-btn--google"
    aria-label={`Open ${title} in Google Maps`}
  >
    <svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
      <path
        fill="currentColor"
        d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"
      ></path>
    </svg>
    Google Maps
  </a>

  <a
    href={am}
    target="_blank"
    rel="noopener noreferrer"
    class="map-btn map-btn--apple"
    aria-label={`Open ${title} in Apple Maps`}
  >
    <svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
      <path
        fill="currentColor"
        d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"
      ></path>
    </svg>
    Apple Maps
  </a>
</div>

<style>
  .map-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .map-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 0.85rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .map-btn:hover {
    opacity: 0.8;
  }

  .map-btn--google {
    background: #1a73e8;
    color: #fff;
  }

  .map-btn--apple {
    background: #000;
    color: #fff;
  }

  @media print {
    /* In print views, replace buttons with plain URLs */
    .map-btn {
      display: none;
    }
  }
</style>
