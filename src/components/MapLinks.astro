---
import { googleMaps, googleDirections, appleMaps } from "@/lib/maplinks";

interface Props {
  lat: number;
  lng: number;
  title: string;
  directions?: boolean;
  class?: string;
}

const { lat, lng, title, directions = false, class: cls } = Astro.props;

const gmSearch = googleMaps(lat, lng);
const gmDir = googleDirections(lat, lng);
const am = appleMaps(lat, lng, title);
---

<div class:list={["map-links", cls]}>
  <a
    href={directions ? gmDir : gmSearch}
    target="_blank"
    rel="noopener noreferrer"
    class="map-link"
    aria-label={`Open ${title} in Google Maps`}
  >
    <svg aria-hidden="true" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
    Google Maps
  </a>

  <a
    href={am}
    target="_blank"
    rel="noopener noreferrer"
    class="map-link"
    aria-label={`Open ${title} in Apple Maps`}
  >
    <svg aria-hidden="true" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
    Apple Maps
  </a>
</div>

<style>
  @media print {
    .map-links { display: none; }
  }
</style>
