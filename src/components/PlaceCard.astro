---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import MapLinks from "./MapLinks.astro";

interface Props {
  place: CollectionEntry<"places">;
  base?: string;
}

const { place, base = "" } = Astro.props;
const { title, category, city, rating, cover, lat, lng } = place.data;
const stars = rating ? "★".repeat(rating) + "☆".repeat(5 - rating) : null;
---

<article class="place-card">
  {
    cover && (
      <a href={`${base}/places/${place.id}`} class="place-card__img-link">
        <Image
          src={cover}
          alt={title}
          width={480}
          height={300}
          class="place-card__img"
        />
      </a>
    )
  }
  <div class="place-card__body">
    <span class="place-card__category">{category}</span>
    <h3 class="place-card__title">
      <a href={`${base}/places/${place.id}`}>{title}</a>
    </h3>
    {stars && <div class="place-card__rating" aria-label={`Rating: ${rating} of 5`}>{stars}</div>}
    <div class="place-card__city">{city}</div>
    <MapLinks {lat} {lng} {title} class="place-card__links" />
  </div>
</article>

<style>
  .place-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
    display: flex;
    flex-direction: column;
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease),
                box-shadow 0.25s var(--ease);
  }
  .place-card:hover {
    transform: translateY(-3px);
    border-color: var(--line-strong);
    box-shadow: 0 14px 30px -18px #211B1633;
  }

  .place-card__img-link {
    display: block;
    overflow: hidden;
  }

  .place-card__img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .place-card__img-link:hover .place-card__img {
    transform: scale(1.03);
  }

  .place-card__body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .place-card__category {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
  }

  .place-card__title a {
    color: inherit;
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 600;
  }
  .place-card__title a:hover {
    text-decoration: underline;
  }

  .place-card__rating {
    font-size: 0.85rem;
    color: var(--star);
    letter-spacing: 0.05em;
  }

  .place-card__city {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .place-card__links {
    margin-top: auto;
    padding-top: 0.6rem;
  }
</style>
